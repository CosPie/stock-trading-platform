 # Yahoo symbols may contain letters, digits, and these structural characters.
 _YAHOO_SAFE = re.compile(r"^[A-Za-z0-9._\-\^=]+$")
+_A_SHARE_CODE = re.compile(r"^\d{6}$")
+_HK_CODE = re.compile(r"^\d{1,5}$")
+
+
+def _a_share_suffix(code: str) -> str | None:
+    """Return Yahoo's exchange suffix for a bare mainland China stock code."""
+    if not _A_SHARE_CODE.fullmatch(code):
+        return None
+    if code.startswith(("600", "601", "603", "605", "688", "689", "900")):
+        return ".SS"
+    if code.startswith(("000", "001", "002", "003", "200", "300", "301")):
+        return ".SZ"
+    if code.startswith(("43", "83", "87", "88", "920")):
+        return ".BJ"
+    return None
+
+
+def is_china_market_symbol(raw: str) -> bool:
+    """True for China/HK-style tickers, including bare local numeric codes."""
+    if not isinstance(raw, str) or not raw.strip():
+        return False
+    s = raw.strip().upper().rstrip("+")
+    if s.endswith((".SS", ".SH", ".SZ", ".BJ", ".HK")):
+        return True
+    return _a_share_suffix(s) is not None or _HK_CODE.fullmatch(s) is not None
 
 
